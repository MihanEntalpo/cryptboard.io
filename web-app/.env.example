# Redis host used by the PHP backend to store sessions, message queues and rate-limit state
REDIS_HOST=localhost

# Redis TCP port
REDIS_PORT=6379

# Redis logical database number
REDIS_DB=1

# Public key used by the backend to verify JWT signatures
# Format: "-----BEGIN PUBLIC KEY-----\n<SomeBase64Data>\n-----END PUBLIC KEY-----"
# Store it in one line with literal "\n", without surrounding quotes
JWT_PUBLIC_KEY=

# Private key used by the backend to sign JWT access and refresh tokens
# Format: "-----BEGIN RSA PRIVATE KEY-----\n<SomeBase64Data>\n-----END RSA PRIVATE KEY-----"
# Store it in one line with literal "\n", without surrounding quotes
JWT_PRIVATE_KEY=

# Public hostname of this installation. Used as JWT issuer ("iss") and must match real host
SERVER_HOST=cryptboard.io

# Access-token lifetime in seconds
JWT_EXPIRE_SECONDS=86400

# Refresh-token lifetime in seconds
JWT_REFRESH_EXPIRE_SECONDS=124800

# Session/UID lifetime in Redis in seconds
UID_EXPIRE_SECONDS=604800

# Lifetime of server-side queued messages in Redis in seconds
MSG_EXPIRE_SECONDS=36000

# Optional Sentry DSN for backend exception reporting
SENTRY_DSN=

# If true, PHP enables display_errors and display_startup_errors
PHP_DEBUG=false

# Frontend debug flag exposed via /js/env.js
JS_DEBUG=1


# =========================
# Frontend runtime config for /js/env.js (safe public values)
# =========================

# Polling interval (ms) for /api/receive-list requests from browser
FRONTEND_POLL_RECEIVE_LIST_MS=1000

# Polling interval (ms) for /api/receive requests from browser
FRONTEND_POLL_RECEIVE_MS=2000

# Polling interval (ms) for auth refresh checks on frontend
FRONTEND_POLL_REFRESH_AUTH_MS=15000

# If true, client-side storage can mark entries as non-expiring
FRONTEND_NO_EXPIRE=false

# Default client-side TTL (seconds) for frontend cached data
FRONTEND_TTL_SECONDS=2678400

# Enable additional frontend ajax debug logs
FRONTEND_AJAX_DEBUG=false

# Enable additional frontend messages debug logs
FRONTEND_MESSAGES_DEBUG=false

# Enable additional frontend files debug logs
FRONTEND_FILES_DEBUG=false

# Enable additional frontend sound-notification debug logs
FRONTEND_SOUND_DEBUG=false
